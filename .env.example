# Core Flask
ASME_SECRET_KEY=change-this-secret
ASME_DATABASE_URL=sqlite:///inventory.db
PORT=5000

# Default bootstrap admin/user
ASME_DEFAULT_ADMIN_EMAIL=admin@uiowa.edu
ASME_DEFAULT_ADMIN_PASSWORD=ChangeMe123!
ASME_DEFAULT_USER_PASSWORD=ChangeMe123!
# Optional shared-admin aliases (fallbacks accepted by admin login)
ASME_SHARED_ADMIN_EMAIL=
ASME_SHARED_ADMIN_PASSWORD=
ASME_ADMIN_EMAIL=
ASME_ADMIN_PASSWORD=

# Admin email overrides for legacy ops backend
ASME_ADMIN_EMAILS=admin@uiowa.edu

# Calendar embeds
ASME_CALENDAR_PROVIDER=google
ASME_GOOGLE_CALENDAR_EMBED_URL=
ASME_OUTLOOK_CALENDAR_EMBED_URL=

# Outlook API integration (optional)
ASME_OUTLOOK_TENANT_ID=
ASME_OUTLOOK_CLIENT_ID=
ASME_OUTLOOK_CLIENT_SECRET=
ASME_OUTLOOK_CALENDAR_USER=
ASME_OUTLOOK_CALENDAR_ID=
ASME_OUTLOOK_CALENDAR_ROBOTICS_ID=
ASME_OUTLOOK_CALENDAR_FLUIDS_ID=
ASME_OUTLOOK_CALENDAR_TZ=Central Standard Time

# SMTP for cancellation + future notifications (optional)
ASME_SMTP_HOST=smtp.office365.com
ASME_SMTP_PORT=587
ASME_SMTP_USER=
ASME_SMTP_PASS=
ASME_CANCEL_NOTIFY_TO=

# Optional printer command automation for legacy ops pages
ASME_H2S_PRINT_CMD=
ASME_P1S_PRINT_CMD=

# Security + upload limits
ASME_LOGIN_RATE_WINDOW_SECONDS=900
ASME_LOGIN_RATE_MAX_ATTEMPTS=8
ASME_PRINT_MAX_UPLOAD_MB=50
